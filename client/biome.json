{
    "$schema": "https://biomejs.dev/schemas/2.0.5/schema.json",
    "files": {
        "includes": ["src/**", "!src/vue-router-better-scroller/**"]
    },
    "linter": {
        "domains": {
            "vue": "recommended"
        },
		"rules": {
			"correctness": {
					"noUnusedFunctionParameters": "off"
				},
			"style": {
				"noNonNullAssertion": "off"
			},
			"suspicious": {
				"noExplicitAny": "off"
			}
		}
    },
    "overrides": [
	{
		"includes": [
			"**/*.vue"
		],
		"linter": {
			"rules": {
				"correctness": {
					"noUnusedImports": "off",
					"noUnusedVariables": "off"
				}
			}
		}
	}
]
}
