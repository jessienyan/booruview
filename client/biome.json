{
	"$schema": "https://biomejs.dev/schemas/2.3.6/schema.json",
	"files": {
		"includes": ["src/**", "!src/vue-router-better-scroller"]
	},
	"formatter": {
		"indentWidth": 4,
		"lineWidth": 120
	},
	"linter": {
		"domains": {
			"vue": "recommended"
		},
		"rules": {
			"correctness": {
				"noUnusedFunctionParameters": "off"
			},
			"style": {
				"noNonNullAssertion": "off"
			},
			"suspicious": {
				"noExplicitAny": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["**/*.vue"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedImports": "off",
						"noUnusedVariables": "off"
					}
				}
			}
		}
	],
	"css": {
		"formatter": {
			"enabled": true
		}
	},
	"javascript": {
		"formatter": {
			"arrowParentheses": "asNeeded"
		}
	}
}
