{
    order geo_ip first
}

{$CADDY_HOST} {
    encode
    request_body {
        max_size 10MB
    }

    log stderr-log {
        level INFO
        output stderr
    }

    # Used to expose a file log for fail2ban
    log file-log {
        level INFO
        output file /var/log/caddy/caddy.log {
            mode 644
        }
    }

    # Clients must always check if index.html changed
    header / Cache-Control "public, no-cache"

    # Assets are hashed and never change so are safe to cache
    header /assets/* Cache-Control "max-age=31536000, immutable"

    # API responses shouldn't be cached by clients, they are too volatile and cached by the API anyway
    header /api/* Cache-Control "no-store"

    # Global headers
    # https://cheatsheetseries.owasp.org/cheatsheets/HTTP_Headers_Cheat_Sheet.html
    header {
        Referrer-Policy                 "same-origin"
        X-Frame-Options                 "DENY"
        X-Content-Type-Options          "nosniff"
        Strict-Transport-Security       "max-age=2592000; includeSubDomains"
        Cross-Origin-Opener-Policy      "same-origin"
        Cross-Origin-Resource-Policy    "same-site"
        Content-Security-Policy         "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' gelbooru.com *.gelbooru.com {$MEDIA_PROXY_HOST_SCHEMELESS}; media-src 'self' gelbooru.com *.gelbooru.com {$MEDIA_PROXY_HOST_SCHEMELESS}; object-src 'none'; frame-src 'none'; base-uri 'none'"
    }

    # Bots running on workers.dev are scanning URLs
    @botscan header "Cf-Worker" *
    abort @botscan

    @longUrl expression {path}.size() > 3000
    error @longUrl "URI Too Long" 414

    handle_errors {
        respond "{err.status_code} {err.status_text}"
    }

    handle_path /api/* {
        ja4h_header
        log_append ja4h {http.request.header.Ja4h}
        geo_ip {
            db_path /etc/caddy/GeoLite2-Country.mmdb
        }
        log_append country {geoip.country_code}
        reverse_proxy http://api:8000
    }

    # Including some common file extensions here will prevent the server from
    # falling back to index.html
    @static path /assets/* *.html *.css *.js *.png *.jpg *.ico *.txt
    handle @static {
        file_server
    }

    # index.html fallback to handle SPA routing
    handle {
        file_server
        try_files {path} /index.html
    }
}

{$GRAFANA_HOST:grafana.localhost} {
    reverse_proxy http://grafana:3000
}
