# Required. The addresses that Caddy will listen to for the site.
# Reference: https://caddyserver.com/docs/caddyfile/concepts#addresses
#
# For example, if:
#
#   CADDY_HOST=booruview.com, www.booruview.com
#
# Then Caddy will listen to both 'booruview.com' and 'www.booruview.com' on https.
CADDY_HOST=:8080

# Optional. Comma separated list of gelbooru credentials to authenticate with. The api will
# rotate between them to avoid limits on a single key. If these aren't blank they must contain
# the same number of entries.
#
# Unless you are expecting a high amount of traffic, a single userid/apikey should be fine
#
# For example, if:
#
#   GELBOORU_USERID=1,2
#   GELBOORU_API_KEY=key1,key2
#
# Then Gelbooru API requests will alternate between using (1, key1) and (2, key2)
GELBOORU_USERID=
GELBOORU_APIKEY=

GRAFANA_HOST=grafana.localhost

# Optional. If set, image/video URLs will be rewritten to use the proxy.
# CAUTION: This will use an extremely high amount of bandwidth!
# Reference: https://caddyserver.com/docs/caddyfile/concepts#addresses
#
# For example, if:
#
#   MEDIA_PROXY_HOST=https://example.com
#
# Then URLs to be rewritten to https://example.com/?to=REAL_GELBOORU_URL
USE_MEDIA_PROXY=0
MEDIA_PROXY_HOST=

# Required. Used for creating user auth tokens. Run this to generate a new key:
# $ python -c 'import secrets; print(secrets.token_urlsafe(32))'
SECRET_KEY=test
