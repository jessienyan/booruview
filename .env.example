# optional. Comma separated list of gelbooru credentials to authenticate with. The api will
# rotate between them to avoid limits on a single key. If these aren't blank they must contain
# the same number of entries
GELBOORU_USERID=
GELBOORU_APIKEY=

# comma separated list of ja4h fingerprints for clients that
# will be getting coal for christmas
NAUGHTY_JA4H_FINGERPRINTS=

# comma separated list of post hashes to use for images. leave
# blank to generate fake ones
FAKEDATA_POST_HASHES=

# required for production when using cloudflare
# https://github.com/caddy-dns/cloudflare?tab=readme-ov-file#configuration
CLOUDFLARE_API_TOKEN=
